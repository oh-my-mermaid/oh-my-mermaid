graph LR
    classDef entry fill:#89b4fa,stroke:#89b4fa,color:#1e1e2e
    classDef store fill:#a6e3a1,stroke:#a6e3a1,color:#1e1e2e

    browser["Browser\n(localhost)"]:::entry
    browser -->|"GET /"| html_handler["HTML Handler\nsrc/server/index.ts"]
    html_handler -->|"injects project name"| viewer_html["viewer.html\nsrc/server/viewer.html"]
    browser -->|"GET /api/classes\nGET /api/class/:name\nGET /api/class/:name/diff\nGET /api/class/:name/refs"| api["API Handler\nsrc/server/api.ts"]
    api -->|"read only"| store["Store / Lib\nsrc/lib/store.ts"]:::store
    browser -->|"GET /events (SSE)"| sse["SSE Endpoint\nsrc/server/index.ts"]
    sse --> watcher["File Watcher\nsrc/server/watcher.ts"]
    watcher -->|"fs.watch .omm/ recursive"| omm_dir[".omm/\nfile system"]:::store
    watcher -->|"broadcast change event (300ms debounce)"| sse
