graph TD
    classDef entry fill:#89b4fa,stroke:#89b4fa,color:#1e1e2e

    sse["SSE /events\n(live reload)"]:::entry
    api["REST API\n/api/*"]:::entry
    sse -->|"change event → refetch"| state["App State\nclasses / activeClass / data"]
    api -->|"fetch on load + navigate"| state
    state -->|"render"| nav["Nav Sidebar\nclass list + tree"]
    state -->|"render"| diagram_canvas["Diagram Canvas\ndagre layout engine"]
    state -->|"render"| detail_sidebar["Detail Sidebar\ndescription / context / constraints\nconcerns / todos / notes"]
    diagram_canvas -->|"@class-name nodes"| nav_ref["Clickable Sub-diagram\ndrills into referenced class"]
    diagram_canvas -->|"node click"| detail_sidebar
    detail_sidebar -->|"outgoing refs"| nav_ref
